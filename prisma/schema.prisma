generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum BandStatus {
  PENDING
  APPROVED
  REJECTED
}

model Region {
  id     String @id @default(cuid())
  name   String @unique
  cities City[]
}

model City {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  regionId  String
  createdAt DateTime @default(now())
  bands     Band[]
  region    Region   @relation(fields: [regionId], references: [id])
  events    Event[]
  venues    Venue[]
}

model Band {
  id           String     @id @default(cuid())
  name         String
  slug         String     @unique
  genre        String[]
  bio          String?
  logoUrl      String?
  spotifyUrl   String?
  instagramUrl String?
  isFeatured   Boolean    @default(false)
  status       BandStatus @default(APPROVED) // 🔥 Nuevo: control de postulaciones
  cityId       String
  createdAt    DateTime   @default(now())
  city         City       @relation(fields: [cityId], references: [id])
}

model Venue {
  id      String  @id @default(cuid())
  name    String
  slug    String  @unique
  address String
  mapsUrl String?
  cityId  String
  events  Event[]
  city    City    @relation(fields: [cityId], references: [id])
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String?
  date        DateTime
  ticketUrl   String?
  isFeatured  Boolean  @default(false)
  cityId      String
  venueId     String
  createdAt   DateTime @default(now())
  city        City     @relation(fields: [cityId], references: [id])
  venue       Venue    @relation(fields: [venueId], references: [id])
}
