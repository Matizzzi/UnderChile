generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum BandStatus {
  PENDING
  APPROVED
  REJECTED
}

model Region {
  id     String @id @default(cuid())
  name   String @unique
  cities City[]
}

model City {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  regionId  String
  createdAt DateTime @default(now())
  bands     Band[]
  region    Region   @relation(fields: [regionId], references: [id])
  events    Event[]
  venues    Venue[]
}

model Band {
  id           String     @id @default(cuid())
  name         String
  slug         String     @unique
  genre        String[]
  bio          String?
  logoUrl      String?
  spotifyUrl   String?
  instagramUrl String?
  isFeatured   Boolean    @default(false)
  status       BandStatus @default(APPROVED)
  cityId       String
  createdAt    DateTime   @default(now())
  city         City       @relation(fields: [cityId], references: [id])
}

model Venue {
  id      String  @id @default(cuid())
  name    String
  slug    String  @unique
  address String
  mapsUrl String?
  cityId  String
  events  Event[]
  city    City    @relation(fields: [cityId], references: [id])
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String?
  date        DateTime
  ticketUrl   String?
  isFeatured  Boolean  @default(false)
  cityId      String
  venueId     String
  createdAt   DateTime @default(now())
  city        City     @relation(fields: [cityId], references: [id])
  venue       Venue    @relation(fields: [venueId], references: [id])
}

// 🔥 NUEVO: registro de auditoría de acciones de moderación
model AuditLog {
  id         String   @id @default(cuid())
  action     String   // ej: "APPROVE_BAND", "REJECT_BAND", "REVERT_TO_PENDING", "TOGGLE_FEATURED"
  targetType String   // ej: "Band" (deja la puerta abierta a Venue/Event en el futuro)
  targetId   String   // id de la entidad afectada
  targetName String   // nombre legible al momento de la acción (por si la banda se borra después)
  actor      String   @default("admin") // hoy es siempre "admin" (un solo usuario); listo para multi-admin a futuro
  details    String?  // info adicional opcional, ej: "isFeatured: true"
  createdAt  DateTime @default(now())

  @@index([targetType, targetId])
  @@index([createdAt])
}