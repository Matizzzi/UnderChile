datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Region {
  id        String   @id @default(cuid())
  name      String   @unique
  cities    City[]
}

model City {
  id        String   @id @default(cuid())
  name      String   
  slug      String   @unique // Ej: "melipilla" -> underchile.cl/melipilla
  regionId  String
  region    Region   @relation(fields: [regionId], references: [id])
  bands     Band[]
  events    Event[]
  venues    Venue[]
  createdAt DateTime @default(now())
}

model Band {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  genre        String[] 
  bio          String?
  logoUrl      String?
  spotifyUrl   String?
  instagramUrl String?
  isFeatured   Boolean  @default(false) // Para destacar bandas ($5-10k)
  cityId       String
  city         City     @relation(fields: [cityId], references: [id])
  createdAt    DateTime @default(now())
}

model Venue {
  id        String   @id @default(cuid())
  name      String   
  slug      String   @unique
  address   String
  mapsUrl   String?
  cityId    String
  city      City     @relation(fields: [cityId], references: [id])
  events    Event[]
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String?
  date        DateTime
  ticketUrl   String?  
  isFeatured  Boolean  @default(false)
  cityId      String
  city        City     @relation(fields: [cityId], references: [id])
  venueId     String
  venue       Venue    @relation(fields: [venueId], references: [id])
  createdAt   DateTime @default(now())
}